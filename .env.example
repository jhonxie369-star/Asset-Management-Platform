# SASP 安全资产扫描平台 — 本地配置
# 首次使用请复制为 .env 并按需修改

# 运行
PORT=3400
HOST=0.0.0.0
DATA_DIR=./backend/data

# 登录认证
# 警告:请修改默认密码,不要提交带真实密码的 .env 到仓库
SASP_USERNAME=admin
SASP_PASSWORD=change-me
SASP_SESSION_SECRET=change-this-to-a-random-long-string

# 可选:允许多用户,用分号分隔 user:pass;user2:pass2
# SASP_USERS=admin:change-me;auditor:change-me-too

# ─── 资产源:CloudQuery PG ─────────────────────────────────────
# 用于从 cloudquery 图数据库同步资产清单(见 /asset-lists 页面的"同步"按钮)
# 推荐整串:
# CLOUDQUERY_PG_URL=postgresql://cloudquery_user@db.example.invalid:5432/cloudquery
# 或拆字段:
# CLOUDQUERY_PG_HOST=db.example.invalid
# CLOUDQUERY_PG_PORT=15432
# CLOUDQUERY_PG_USER=cloudquery_user
# CLOUDQUERY_PG_PASSWORD=xxx
# CLOUDQUERY_PG_DATABASE=cloudquery
# 内网可达 CIDR 白名单文件(一行一条,# 注释)
# CLOUDQUERY_REACHABLE_CIDRS_FILE=./backend/data/reachable-cidrs.txt
